{
  "ConnectionStrings": {
    "Default": "Data Source=enhancementhub.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Jwt": {
    "Secret": "dev-secret-change-in-production-min-32-chars!!",
    "Issuer": "EnhancementHub",
    "Audience": "EnhancementHub"
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini"
  },
  "Authentication": {
    "OpenIdConnect": {
      "Enabled": false,
      "Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-oidc",
      "SignedOutCallbackPath": "/signout-callback-oidc",
      "DefaultRole": "Developer",
      "Scopes": [ "openid", "profile", "email" ],
      "RoleMappings": {
        "00000000-0000-0000-0000-000000000001": "Admin",
        "00000000-0000-0000-0000-000000000002": "Approver"
      }
    }
  },
  "VectorSearch": {
    "Provider": "InMemory",
    "Dimensions": 64,
    "Qdrant": {
      "Url": "http://localhost:6333",
      "Collection": "indexed_files"
    },
    "AzureSearch": {
      "Endpoint": "https://your-search.search.windows.net",
      "ApiKey": "",
      "IndexName": "indexed-files"
    }
  },
  "Storage": {
    "Provider": "Local",
    "LocalRoot": "uploads",
    "S3": {
      "Bucket": "",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "AccessKey": "",
      "SecretKey": "",
      "ForcePathStyle": false,
      "PresignedUrlExpiryMinutes": 60
    }
  },
  "Repositories": {
    "CloneRoot": "repo-clones",
    "ArchiveMaxSizeBytes": 500000000
  },
  "GitHubApp": {
    "AppId": "",
    "PrivateKey": "",
    "PrivateKeyPath": "",
    "InstallationId": ""
  },
  "Onboarding": {
    "ApiBaseUrl": "http://localhost:5075"
  },
  "Attachments": {
    "Scanning": {
      "Enabled": true,
      "MaxFileSizeBytes": 20000000,
      "ClamAv": {
        "Enabled": false,
        "Required": false,
        "Host": "localhost",
        "Port": 3310
      }
    }
  },
  "Notifications": {
    "Email": {
      "Enabled": false,
      "SmtpHost": "",
      "SmtpPort": 587,
      "UseSsl": true,
      "FromAddress": "noreply@enhancementhub.dev",
      "FromName": "EnhancementHub",
      "Username": "",
      "Password": "",
      "ToAddresses": []
    },
    "Teams": {
      "Enabled": false,
      "WebhookUrl": ""
    }
  },
  "Commercial": {
    "Enabled": true,
    "SelfServiceSignupEnabled": true,
    "TrialDays": 14,
    "DefaultRegion": "US",
    "TrialLimits": {
      "MaxApplications": 3,
      "MaxAnalysesPerMonth": 50,
      "MaxStorageMegabytes": 500
    },
    "TeamLimits": {
      "MaxApplications": 25,
      "MaxAnalysesPerMonth": 500,
      "MaxStorageMegabytes": 5000
    },
    "EnterpriseLimits": {
      "MaxApplications": 500,
      "MaxAnalysesPerMonth": 10000,
      "MaxStorageMegabytes": 100000
    }
  },
  "Stripe": {
    "Enabled": false,
    "SecretKey": "",
    "WebhookSecret": "",
    "PublishableKey": "",
    "SuccessUrl": "http://localhost:5001/Admin/Tenancy?checkout=success",
    "CancelUrl": "http://localhost:5001/Admin/Tenancy?checkout=cancel",
    "PortalReturnUrl": "http://localhost:5001/Admin/Tenancy",
    "Prices": {
      "Team": "",
      "Enterprise": ""
    }
  },
  "TenantIsolation": {
    "Enabled": false,
    "SchemaPrefix": "tenant_",
    "AutoProvisionEnterprise": true,
    "AutoProvisionEuRegion": false
  },
  "Features": {
    "IntakeCopilot": true,
    "ApprovalCopilot": true,
    "GlobalSearch": true,
    "SemanticSearch": true,
    "FeedbackWidget": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
