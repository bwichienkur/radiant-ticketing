@page
@model EnhancementHub.Web.Pages.EnhancementRequests.IndexModel
@{
    ViewData["Title"] = "Enhancement Requests";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Enhancement Requests</h1>
        <p>All submitted enhancement requests</p>
    </div>
    <a asp-page="Create" class="btn btn-primary">New Request</a>
</div>

<div class="card-panel">
    <div class="table-responsive">
        <table class="table table-hover table-enterprise mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Application</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Submitted By</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Requests)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@(item.TargetApplicationName ?? "—")</td>
                    <td>@item.Priority</td>
                    <td><span class="badge text-bg-secondary badge-status">@item.Status</span></td>
                    <td>@(item.SubmittedByUserName ?? "—")</td>
                    <td>@item.CreatedAt.ToString("g")</td>
                    <td><a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
