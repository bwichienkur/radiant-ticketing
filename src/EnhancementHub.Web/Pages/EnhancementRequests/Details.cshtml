@page "{id:guid}"
@model EnhancementHub.Web.Pages.EnhancementRequests.DetailsModel
@using EnhancementHub.Domain.Enums
@{
    ViewData["Title"] = Model.Detail?.Title ?? "Request Details";
    ViewData["Breadcrumb"] = "Request detail";
    var r = Model.Detail!;
    var analysis = Model.Analysis;

    string RiskBadgeClass(RiskLevel risk) => risk switch
    {
        RiskLevel.Critical => "text-bg-danger",
        RiskLevel.High => "text-bg-warning",
        RiskLevel.Medium => "text-bg-info",
        _ => "text-bg-success"
    };
}

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
        <h1 id="request-detail-title">@r.Title</h1>
        <p>
            <span class="badge text-bg-secondary badge-status" aria-label="Status @r.Status">@r.Status</span>
            <span class="text-muted ms-2">Submitted by @r.SubmittedByUserName on @r.CreatedAt.ToString("g")</span>
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/Spa/ApprovalQueue" class="btn btn-outline-primary btn-sm">Approval queue</a>
    </div>
</div>

<div id="analysis-update-banner" class="alert alert-info d-none mb-3" role="status" aria-live="polite"></div>

@if (analysis is not null)
{
    <div class="card-panel p-4 mb-4 analysis-summary-banner">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div class="flex-grow-1">
                <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                    <h2 class="h5 mb-0">AI Analysis</h2>
                    <span class="badge @RiskBadgeClass(analysis.RiskLevel) badge-status">@analysis.RiskLevel risk</span>
                    @if (analysis.NeedsClarification)
                    {
                        <span class="badge text-bg-secondary badge-status">Clarification needed</span>
                    }
                </div>
                <p class="mb-0">@(analysis.FeatureSummary ?? "Analysis complete — see details below.")</p>
            </div>
            <div class="d-flex gap-3">
                <div class="text-center">
                    <div class="small text-muted">Confidence</div>
                    <div class="fw-semibold fs-5">@($"{analysis.ConfidenceScore:P0}")</div>
                </div>
                <div class="text-center">
                    <div class="small text-muted">Version</div>
                    <div class="fw-semibold fs-5">@analysis.Version</div>
                </div>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(analysis.RiskExplanation))
        {
            <p class="text-muted small mb-0 mt-3"><strong>Risk:</strong> @analysis.RiskExplanation</p>
        }
    </div>
}
else if (r.Status is EnhancementRequestStatus.Submitted or EnhancementRequestStatus.AiAnalyzing)
{
    <div class="card-panel p-4 mb-4" id="analysis-in-progress">
        <div class="d-flex align-items-center gap-2">
            <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
            <span>AI analysis is in progress. This page will refresh automatically.</span>
        </div>
    </div>
}

@if (analysis is not null && (analysis.AffectedApplications.Count > 0 || analysis.DatabaseChangeRecommendations.Count > 0))
{
    <div class="card-panel p-4 mb-4">
        <h2 class="h6 mb-3">Mission control</h2>
        <div class="mission-control-grid">
            <div class="stat-card"><div class="label">Risk</div><div class="value fs-5"><span class="badge @RiskBadgeClass(analysis.RiskLevel)">@analysis.RiskLevel</span></div></div>
            <div class="stat-card"><div class="label">Confidence</div><div class="value fs-5">@($"{analysis.ConfidenceScore:P0}")</div></div>
            <div class="stat-card"><div class="label">Affected apps</div><div class="value fs-5">@analysis.AffectedApplications.Count</div></div>
            <div class="stat-card"><div class="label">DB / API changes</div><div class="value fs-5">@analysis.DatabaseChangeRecommendations.Count / @analysis.ApiChangeRecommendations.Count</div></div>
        </div>
        @if (r.TargetApplicationId.HasValue)
        {
            <div class="mt-3">
                <a href="/Spa/SystemMap?applicationId=@r.TargetApplicationId" class="btn btn-sm btn-outline-primary">Open system map</a>
            </div>
        }
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card-panel p-4 mb-4">
            <div class="eh-accordion open" data-eh-accordion>
                <button type="button" class="eh-accordion-trigger" data-eh-accordion-trigger aria-expanded="true">Original ask</button>
                <div class="eh-accordion-body" data-eh-accordion-body>
                    <p class="mb-2"><strong>Business description</strong></p>
                    <p>@r.BusinessDescription</p>
                    <p class="mb-2"><strong>Desired outcome</strong></p>
                    <p class="mb-0">@r.DesiredOutcome</p>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(r.SupportingNotes))
            {
                <div class="eh-accordion" data-eh-accordion>
                    <button type="button" class="eh-accordion-trigger" data-eh-accordion-trigger aria-expanded="false">Supporting notes</button>
                    <div class="eh-accordion-body" data-eh-accordion-body hidden>
                        <p class="mb-0">@r.SupportingNotes</p>
                    </div>
                </div>
            }
        </div>

        @if (analysis is not null)
        {
            <div class="card-panel p-4 mb-4">
                <div class="detail-section">
                    <h3>AI Summary</h3>
                    <p>@(analysis.FeatureSummary ?? "—")</p>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="label">Risk</div>
                            <div class="value fs-4"><span class="badge @RiskBadgeClass(analysis.RiskLevel)">@analysis.RiskLevel</span></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="label">Confidence</div>
                            <div class="value fs-4">@($"{analysis.ConfidenceScore:P0}")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="label">Clarification</div>
                            <div class="value fs-4">@(analysis.NeedsClarification ? "Needed" : "No")</div>
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(analysis.RiskExplanation))
                {
                    <div class="detail-section mt-3">
                        <h3>Risk Explanation</h3>
                        <p class="mb-0">@analysis.RiskExplanation</p>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(analysis.TechnicalRequirements))
                {
                    <div class="detail-section">
                        <h3>Technical Requirements</h3>
                        <pre class="mb-0 small">@analysis.TechnicalRequirements</pre>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(analysis.TestingPlan))
                {
                    <div class="detail-section">
                        <h3>Testing Plan</h3>
                        <p class="mb-0">@analysis.TestingPlan</p>
                    </div>
                }
                @if (analysis.AffectedApplications.Count > 0)
                {
                    <div class="detail-section">
                        <h3>Affected Applications</h3>
                        <ul class="mb-0">@foreach (var a in analysis.AffectedApplications) { <li>@(a.ApplicationName ?? a.ApplicationId.ToString())</li> }</ul>
                    </div>
                }
                @if (analysis.DatabaseChangeRecommendations.Count > 0)
                {
                    <div class="detail-section">
                        <h3>Database Changes</h3>
                        <table class="table table-sm">
                            <thead><tr><th>Table</th><th>Type</th><th>Description</th></tr></thead>
                            <tbody>
                            @foreach (var d in analysis.DatabaseChangeRecommendations)
                            {
                                <tr><td>@d.TableName</td><td>@d.ChangeType</td><td>@d.Description</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                @if (analysis.ApiChangeRecommendations.Count > 0)
                {
                    <div class="detail-section">
                        <h3>API Changes</h3>
                        <table class="table table-sm">
                            <thead><tr><th>Endpoint</th><th>Type</th><th>Description</th></tr></thead>
                            <tbody>
                            @foreach (var a in analysis.ApiChangeRecommendations)
                            {
                                <tr><td>@a.Endpoint</td><td>@a.ChangeType</td><td>@a.Description</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        @if (Model.Comparison is not null)
        {
            var cmp = Model.Comparison;
            <div class="card-panel p-4 mb-4">
                <div class="detail-section">
                    <h3>AI vs architect comparison</h3>
                    <p class="text-muted small">Version @cmp.VersionA → @cmp.VersionB · @cmp.ArchitectEditsBetweenVersions architect edit(s)</p>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="stat-card">
                            <div class="label">Risk (v@cmp.VersionA → v@cmp.VersionB)</div>
                            <div class="value fs-6">@cmp.RiskLevelA → @cmp.RiskLevelB</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="stat-card">
                            <div class="label">Confidence</div>
                            <div class="value fs-6">@($"{cmp.ConfidenceScoreA:P0}") → @($"{cmp.ConfidenceScoreB:P0}")</div>
                        </div>
                    </div>
                </div>
                @if (cmp.FieldChanges.Any(f => f.Changed))
                {
                    <table class="table table-sm">
                        <thead><tr><th>Field</th><th>Before</th><th>After</th></tr></thead>
                        <tbody>
                        @foreach (var field in cmp.FieldChanges.Where(f => f.Changed))
                        {
                            <tr>
                                <td>@field.FieldName</td>
                                <td class="small text-muted">@(field.ValueA ?? "—")</td>
                                <td class="small">@(field.ValueB ?? "—")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                @if (cmp.FindingChanges.Any(f => f.ChangeType != EnhancementHub.Application.Features.Analysis.Dtos.ComparisonChangeType.Unchanged))
                {
                    <h4 class="h6 mt-3">Finding changes</h4>
                    <ul class="small mb-0">
                    @foreach (var finding in cmp.FindingChanges.Where(f => f.ChangeType != EnhancementHub.Application.Features.Analysis.Dtos.ComparisonChangeType.Unchanged))
                    {
                        <li>@finding.ChangeType: @finding.Title (@finding.Category)</li>
                    }
                    </ul>
                }
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card-panel p-3 mb-4" id="collaboration-panel" data-request-id="@r.Id">
            <div class="card-header px-0 d-flex justify-content-between align-items-center">
                <span>Live collaboration</span>
                <span id="collaboration-presence" class="small text-muted" aria-live="polite">Connecting…</span>
            </div>
            <div class="card-body px-0">
                <form method="post" asp-page-handler="Comment" class="mb-3">
                    <input type="hidden" name="id" value="@r.Id" />
                    <label class="form-label" for="NewComment">Add comment</label>
                    <textarea class="form-control" asp-for="NewComment" id="NewComment" rows="2"></textarea>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" asp-for="CommentIsInternal" id="CommentIsInternal" />
                        <label class="form-check-label" for="CommentIsInternal">Internal only</label>
                    </div>
                    <button type="submit" class="btn btn-outline-primary btn-sm mt-2">Post comment</button>
                </form>
                <div id="collaboration-live-comments" aria-live="polite" aria-relevant="additions">
                    @foreach (var c in r.Comments.OrderByDescending(x => x.CreatedAt).Take(8))
                    {
                        <div class="border-bottom py-2">
                            <strong>@c.UserDisplayName</strong>
                            @if (c.IsInternal) { <span class="badge text-bg-warning">Internal</span> }
                            <span class="small text-muted">@c.CreatedAt.ToString("g")</span>
                            <p class="small mb-0">@c.Content</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card-panel p-3">
            <div class="card-header px-0">Approval history</div>
            <div class="card-body px-0">
                @if (Model.ApprovalHistory.Count == 0)
                {
                    <p class="text-muted small mb-0">No approval actions yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                    @foreach (var action in Model.ApprovalHistory)
                    {
                        <li class="list-group-item px-0">
                            <strong>@action.ActionType</strong> by @action.UserDisplayName<br />
                            <span class="text-muted small">@action.CreatedAt.ToString("g")</span>
                            @if (!string.IsNullOrWhiteSpace(action.Comments)) { <p class="small mb-0 mt-1">@action.Comments</p> }
                        </li>
                    }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/collaboration/request-detail.js" asp-append-version="true"></script>
}
