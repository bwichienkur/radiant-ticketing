@page
@model EnhancementHub.Web.Pages.Applications.IndexModel
@{
    ViewData["Title"] = "Applications";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Applications</h1>
        <p>Registered enterprise applications</p>
    </div>
    <a asp-page="/Onboarding/Wizard" class="btn btn-primary">Document new application</a>
</div>

@if (!Model.Applications.Any())
{
    <div class="card-panel p-5 text-center">
        <h2 class="h5">No applications yet</h2>
        <p class="text-muted mb-4">Use the guided setup wizard to register your first application, connect code and databases, and generate documentation.</p>
        <a asp-page="/Onboarding/Wizard" class="btn btn-primary">Start setup wizard</a>
    </div>
}
else
{
<div class="card-panel">
    <table class="table table-hover table-enterprise mb-0">
        <thead><tr><th>Name</th><th>Domain</th><th>Repositories</th><th></th></tr></thead>
        <tbody>
        @foreach (var app in Model.Applications)
        {
            <tr>
                <td>@app.Name</td>
                <td>@(app.BusinessDomain ?? "—")</td>
                <td>@app.RepositoryCount</td>
                <td><a asp-page="Details" asp-route-id="@app.Id" class="btn btn-sm btn-outline-primary">Profile</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
}
