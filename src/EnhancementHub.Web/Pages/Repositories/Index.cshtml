@page
@model EnhancementHub.Web.Pages.Repositories.IndexModel
@{
    ViewData["Title"] = "Repositories";
    ViewData["PageHeaderTitle"] = "Repositories";
    ViewData["PageHeaderDescription"] = "Source repository indexing status";
}

<header class="page-header d-flex justify-content-between align-items-start flex-wrap gap-3">
    <partial name="_PageHeader" />
    <div class="page-header-actions d-flex flex-wrap gap-2">
        <a href="/Spa/OnboardingWizard" class="btn btn-outline-primary">Add via setup wizard</a>
    </div>
</header>

@if (!Model.Repositories.Any())
{
    ViewData["EmptyStateTitle"] = "No repositories connected";
    ViewData["EmptyStateDescription"] = "Connect a local repository clone during application onboarding to index code and build architecture intelligence.";
    ViewData["EmptyStateIcon"] = "document";
    ViewData["EmptyStateActionUrl"] = "/Spa/OnboardingWizard";
    ViewData["EmptyStateActionText"] = "Start setup wizard";
    <partial name="_EmptyState" />
}
else
{
<div class="card-panel">
    <div class="table-responsive">
        <table class="table table-hover table-enterprise mb-0">
            <thead>
                <tr><th scope="col">Name</th><th scope="col">Application</th><th scope="col">URL</th><th scope="col">Status</th><th scope="col">Last indexed</th><th scope="col"></th></tr>
            </thead>
            <tbody>
            @foreach (var repo in Model.Repositories)
            {
                <tr>
                    <td><strong>@repo.Name</strong></td>
                    <td>@(repo.ApplicationName ?? "—")</td>
                    <td class="small text-truncate" style="max-width:200px">@repo.Url</td>
                    <td><span class="badge text-bg-secondary badge-status">@repo.IndexingStatus</span></td>
                    <td>@(repo.LastIndexedAt?.ToString("g") ?? "—")</td>
                    <td class="text-end">
                        <form method="post" asp-page-handler="Trigger" class="d-inline">
                            <input type="hidden" name="id" value="@repo.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Re-index</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
}
