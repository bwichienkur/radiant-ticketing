@page "{id?}"
@model EnhancementHub.Web.Pages.Spa.ApprovalQueueModel
@{
    ViewData["Title"] = "Approval Queue (React)";
    ViewData["Breadcrumb"] = "Approvals";
}

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
        <h1 id="approval-queue-heading">Approval Queue</h1>
        <p class="text-muted mb-0">React SPA — decision-first review · <kbd>J</kbd>/<kbd>K</kbd> navigate</p>
    </div>
    <a asp-page="/EnhancementRequests/Approve" asp-route-id="@Model.RequestId" class="btn btn-outline-secondary btn-sm">
        Classic view
    </a>
</div>

<div id="spa-approval-queue-root" data-request-id="@(Model.RequestId?.ToString() ?? string.Empty)"></div>

@section Scripts {
    <script type="module" src="~/spa/react/approval-queue.js" asp-append-version="true"></script>
}
