@page
@model EnhancementHub.Web.Pages.Spa.SystemMapModel
@{
    ViewData["Title"] = "System Map (React)";
}

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
        <h1>System map</h1>
        <p class="text-muted mb-0">React SPA — interactive graph explorer</p>
    </div>
    <a asp-page="/SystemMap/Index" class="btn btn-outline-secondary btn-sm">Classic view</a>
</div>

<div
    id="spa-system-map-root"
    data-application-id="@(Model.ApplicationId?.ToString() ?? string.Empty)"></div>

@section Scripts {
    <script type="module" src="~/spa/react/system-map.js" asp-append-version="true"></script>
}
