@page "{id:guid}"
@model EnhancementHub.Web.Pages.Spa.RequestDetailModel
@{
    ViewData["Title"] = "Request (React)";
}

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
        <h1>Enhanced request view</h1>
        <p class="text-muted mb-0">React SPA — client-rendered from BFF endpoints</p>
    </div>
    <a asp-page="/EnhancementRequests/Details" asp-route-id="@Model.RequestId" class="btn btn-outline-secondary btn-sm">
        Classic view
    </a>
</div>

<div id="spa-request-detail-root" data-request-id="@Model.RequestId"></div>

@section Scripts {
    <script type="module" src="~/spa/react/request-detail.js" asp-append-version="true"></script>
}
