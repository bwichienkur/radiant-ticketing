@page "{id:guid}"
@model EnhancementHub.Web.Pages.Spa.RequestDetailModel
@{
    ViewData["Title"] = "Request (SPA pilot)";
}

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
        <h1>Enhanced request view</h1>
        <p class="text-muted mb-0">SPA pilot — client-rendered from REST API</p>
    </div>
    <a asp-page="/EnhancementRequests/Details" asp-route-id="@Model.RequestId" class="btn btn-outline-secondary btn-sm">
        Classic view
    </a>
</div>

<div id="spa-request-detail" data-request-id="@Model.RequestId" aria-live="polite">
    <p id="spa-status" class="text-muted" role="status">Loading…</p>
    <div id="spa-content" aria-busy="true"></div>
</div>

@section Scripts {
    <script src="~/js/spa/request-detail.js" asp-append-version="true"></script>
}
