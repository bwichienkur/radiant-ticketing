@page
@model EnhancementHub.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1>Dashboard</h1>
        <p>Enhancement request pipeline overview</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Onboarding/Wizard" class="btn btn-outline-primary">Document an application</a>
        <a asp-page="/EnhancementRequests/Create" class="btn btn-primary">New Request</a>
    </div>
</div>

@if (Model.OnboardingStatus is not null && Model.ShowOnboardingChecklist)
{
    <div class="card-panel p-4 mb-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
            <div>
                <h2 class="h5 mb-1">Getting started</h2>
                <p class="text-muted mb-0">Complete these steps to document your first application.</p>
            </div>
            @if (Model.OnboardingStatus.ActiveSessionId.HasValue)
            {
                <a asp-page="/Onboarding/Wizard" asp-route-id="@Model.OnboardingStatus.ActiveSessionId" class="btn btn-sm btn-primary">Resume wizard</a>
            }
            else
            {
                <a asp-page="/Onboarding/Wizard" class="btn btn-sm btn-primary">Start wizard</a>
            }
        </div>
        <div class="onboarding-checklist">
            <div class="checklist-item @(Model.OnboardingStatus.ApplicationCount > 0 ? "done" : "")">
                <span class="check">@(Model.OnboardingStatus.ApplicationCount > 0 ? "✓" : "1")</span>
                <span>Register an application</span>
            </div>
            <div class="checklist-item @(Model.OnboardingStatus.RepositoryCount > 0 ? "done" : "")">
                <span class="check">@(Model.OnboardingStatus.RepositoryCount > 0 ? "✓" : "2")</span>
                <span>Connect a repository</span>
            </div>
            <div class="checklist-item @(Model.OnboardingStatus.DatabaseConnectionCount > 0 ? "done" : "")">
                <span class="check">@(Model.OnboardingStatus.DatabaseConnectionCount > 0 ? "✓" : "3")</span>
                <span>Connect a database</span>
            </div>
            <div class="checklist-item @(Model.OnboardingStatus.HasIndexedRepository ? "done" : "")">
                <span class="check">@(Model.OnboardingStatus.HasIndexedRepository ? "✓" : "4")</span>
                <span>Run code discovery</span>
            </div>
            <div class="checklist-item @(Model.OnboardingStatus.HasSystemGraph ? "done" : "")">
                <span class="check">@(Model.OnboardingStatus.HasSystemGraph ? "✓" : "5")</span>
                <span>Build system map & export docs</span>
            </div>
        </div>
    </div>
}

@if (Model.Report is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="stat-card"><div class="label">Total Requests</div><div class="value">@Model.Report.TotalRequests</div></div></div>
        <div class="col-md-3">
            <a asp-page="/EnhancementRequests/Index" class="text-decoration-none">
                <div class="stat-card stat-card-link">
                    <div class="label">Awaiting Analysis</div>
                    <div class="value text-info">@Model.Report.AwaitingAnalysisCount</div>
                </div>
            </a>
        </div>
        <div class="col-md-3"><div class="stat-card"><div class="label">Pending Approval</div><div class="value text-warning">@Model.Report.PendingApprovalCount</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="label">Ready for Dev</div><div class="value text-success">@Model.Report.ReadyForDevelopmentCount</div></div></div>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <a asp-page="/EnhancementRequests/Approve" class="text-decoration-none">
                <div class="stat-card stat-card-link">
                    <div class="label">High-Risk Pending Approval</div>
                    <div class="value text-danger">@Model.Report.HighRiskPendingApprovalCount</div>
                </div>
            </a>
        </div>
        <div class="col-md-4"><div class="stat-card"><div class="label">High Risk (all)</div><div class="value text-danger">@Model.Report.HighRiskCount</div></div></div>
        <div class="col-md-4"><div class="stat-card"><div class="label">Critical Risk</div><div class="value">@Model.Report.CriticalRiskCount</div></div></div>
    </div>
    <div class="row g-3">
        <div class="col-md-4"><div class="stat-card"><div class="label">Avg Approval Time</div><div class="value fs-4">@(Model.Report.AverageApprovalTimeHours?.ToString("F1") ?? "—")<span class="fs-6"> hrs</span></div></div></div>
        <div class="col-md-4"><div class="stat-card"><div class="label">Statuses Tracked</div><div class="value fs-4">@Model.Report.RequestsByStatus.Count</div></div></div>
        <div class="col-md-4 d-flex align-items-stretch">
            <div class="stat-card w-100 d-flex flex-column justify-content-center">
                <div class="label">Quick actions</div>
                <div class="d-flex flex-wrap gap-2 mt-2">
                    <a asp-page="/EnhancementRequests/Approve" class="btn btn-sm btn-outline-warning">Approval queue</a>
                    <a asp-page="/EnhancementRequests/Create" class="btn btn-sm btn-outline-primary">New request</a>
                </div>
            </div>
        </div>
    </div>
}

<button class="btn btn-outline-secondary btn-sm theme-toggle" type="button" onclick="toggleTheme()">Toggle theme</button>

@section Scripts {
<script>
function toggleTheme() {
    const html = document.documentElement;
    const next = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-bs-theme', next);
}
</script>
}
