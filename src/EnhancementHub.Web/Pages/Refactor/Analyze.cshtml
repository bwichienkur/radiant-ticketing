@page
@model EnhancementHub.Web.Pages.Refactor.AnalyzeModel
@{
    ViewData["Title"] = "Refactor Analysis";
    ViewData["Breadcrumb"] = "Refactor";
}

<div class="page-header">
    <h1>Refactor blast-radius analysis</h1>
    <p>Estimate impact before large-scale code changes</p>
</div>

<div class="card-panel p-4 mb-4">
    <form method="post" class="row g-3 col-lg-8">
        <div class="col-md-5">
            <label class="form-label" for="ApplicationId">Application</label>
            <select asp-for="ApplicationId" class="form-select" id="ApplicationId">
                @foreach (var app in Model.Applications)
                {
                    <option value="@app.Id">@app.Name</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <label class="form-label" for="Target">Target</label>
            <input asp-for="Target" class="form-control" id="Target" placeholder="Table or entity name" />
        </div>
        <div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100">Analyze</button></div>
    </form>
</div>

@if (Model.Result is not null)
{
    <div class="card-panel mb-4">
        <div class="card-header">Blast radius for <strong>@Model.Result.TargetName</strong></div>
        <ul class="list-group list-group-flush">
            @foreach (var item in Model.Result.AffectedItems)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span>@item.Name <span class="badge text-bg-secondary">@item.Type</span></span>
                    <span class="text-muted small">@item.Impact (depth @item.Depth)</span>
                </li>
            }
        </ul>
    </div>
    <form method="post" asp-page-handler="GeneratePlan">
        <input type="hidden" asp-for="ApplicationId" />
        <input type="hidden" asp-for="Target" />
        <button type="submit" class="btn btn-outline-primary">Generate refactor plan</button>
    </form>
}
