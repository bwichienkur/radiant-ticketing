@page
@model EnhancementHub.Web.Pages.Refactor.PlansModel
@{
    ViewData["Title"] = "Refactor Plans";
    ViewData["PageHeaderTitle"] = "Refactor plans";
    ViewData["PageHeaderDescription"] = "Saved blast-radius analyses and implementation plans";
}

<header class="page-header d-flex justify-content-between align-items-start flex-wrap gap-3">
    <partial name="_PageHeader" />
    <div class="page-header-actions">
        <a class="btn btn-primary" asp-page="Analyze">New analysis</a>
    </div>
</header>

@if (!Model.Plans.Any())
{
    ViewData["EmptyStateTitle"] = "No refactor plans yet";
    ViewData["EmptyStateDescription"] = "Run a blast-radius analysis to generate your first refactor plan.";
    ViewData["EmptyStateIcon"] = "document";
    ViewData["EmptyStateActionUrl"] = "/Refactor/Analyze";
    ViewData["EmptyStateActionText"] = "Start analysis";
    <partial name="_EmptyState" />
}
else
{
<div class="card-panel">
    <div class="table-responsive">
        <table class="table table-hover table-enterprise mb-0">
            <thead><tr><th scope="col">Title</th><th scope="col">Target</th><th scope="col">Risk</th><th scope="col">Status</th><th scope="col">Created</th></tr></thead>
            <tbody>
            @foreach (var plan in Model.Plans)
            {
                <tr>
                    <td><a asp-page="Plans" asp-route-planId="@plan.Id">@plan.Title</a></td>
                    <td>@plan.TargetDescription</td>
                    <td><span class="badge text-bg-warning badge-status">@plan.RiskLevel</span></td>
                    <td>@plan.Status</td>
                    <td>@plan.CreatedAt.ToString("g")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
}

@if (Model.SelectedPlan is not null)
{
    <div class="card-panel mt-4 p-4">
        <h2 class="eh-section-title mb-3">@Model.SelectedPlan.Title</h2>
        <pre class="mb-0 small">@Model.SelectedPlan.PlanMarkdown</pre>
    </div>
}
