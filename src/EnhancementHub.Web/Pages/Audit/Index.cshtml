@page
@model EnhancementHub.Web.Pages.Audit.IndexModel
@{
    ViewData["Title"] = "Audit Log";
    ViewData["PageHeaderTitle"] = "Audit Log";
    ViewData["PageHeaderDescription"] = "System activity and change history";
}

<header class="page-header d-flex justify-content-between align-items-start flex-wrap gap-3">
    <partial name="_PageHeader" />
    @if (User.IsInRole("Admin"))
    {
        <div class="page-header-actions d-flex flex-wrap gap-2">
            <a asp-page="./Index" asp-page-handler="Export" asp-route-format="csv"
               asp-route-entityType="@Model.EntityType" asp-route-action="@Model.Action"
               asp-route-from="@Model.From?.ToString("yyyy-MM-dd")" asp-route-to="@Model.To?.ToString("yyyy-MM-dd")"
               class="btn btn-outline-primary btn-sm">Export CSV</a>
            <a asp-page="./Index" asp-page-handler="Export" asp-route-format="json"
               asp-route-entityType="@Model.EntityType" asp-route-action="@Model.Action"
               asp-route-from="@Model.From?.ToString("yyyy-MM-dd")" asp-route-to="@Model.To?.ToString("yyyy-MM-dd")"
               class="btn btn-outline-secondary btn-sm">Export JSON</a>
        </div>
    }
</header>

<div class="card-panel p-3 mb-3 eh-filter-panel">
    <form method="get" class="row g-2 align-items-end" aria-label="Filter audit log">
        <div class="col-md-3">
            <label class="form-label small" for="audit-entity-type">Entity type</label>
            <input class="form-control" id="audit-entity-type" name="EntityType" value="@Model.EntityType" placeholder="EnhancementRequest" />
        </div>
        <div class="col-md-3">
            <label class="form-label small" for="audit-action">Action</label>
            <input class="form-control" id="audit-action" name="Action" value="@Model.Action" placeholder="Approved" />
        </div>
        <div class="col-md-2">
            <label class="form-label small" for="audit-from">From</label>
            <input class="form-control" id="audit-from" type="date" name="From" value="@Model.From?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <label class="form-label small" for="audit-to">To</label>
            <input class="form-control" id="audit-to" type="date" name="To" value="@Model.To?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Apply filters</button>
        </div>
    </form>
</div>

@if (Model.Logs.Count == 0)
{
    ViewData["EmptyStateTitle"] = "No audit entries";
    ViewData["EmptyStateDescription"] = "No audit entries match the current filters.";
    ViewData["EmptyStateIcon"] = "search";
    <partial name="_EmptyState" />
}
else
{
    <div class="card-panel">
        <table class="table table-hover table-enterprise mb-0">
            <thead><tr><th>Time (UTC)</th><th>Action</th><th>Entity</th><th>User</th><th>Details</th></tr></thead>
            <tbody>
            @foreach (var log in Model.Logs)
            {
                <tr>
                    <td class="small">@log.CreatedAt.ToString("u")</td>
                    <td>@log.Action</td>
                    <td>@log.EntityType</td>
                    <td>@(log.UserName ?? "—")</td>
                    <td class="small">@(log.Comments ?? "—")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
