@page
@model EnhancementHub.Web.Pages.Admin.TenancyModel
@{
    ViewData["AdminSection"] = "tenancy";
    ViewData["Title"] = "Tenancy & Billing";
    var billing = Model.Billing;
    var isolation = Model.Isolation;
}

<partial name="_AdminNav" />
<div class="page-header">
    <h1>Tenancy &amp; billing</h1>
    <p>Plan limits, usage metering, and Stripe subscription management</p>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (billing is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="label">Plan</div>
                <div class="value fs-5">@billing.Plan</div>
                <div class="small text-muted">@billing.Region region</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="label">Applications</div>
                <div class="value fs-5">@billing.ApplicationCount / @billing.MaxApplications</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="label">Analyses (month)</div>
                <div class="value fs-5">@billing.AnalysisCountThisMonth / @billing.MaxAnalysesPerMonth</div>
            </div>
        </div>
    </div>

    <div class="card-panel p-4 mb-4">
        <h2 class="h5 mb-3">Subscription</h2>
        <dl class="row mb-0">
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@billing.SubscriptionStatus</dd>
            @if (billing.SubscriptionPeriodEnd.HasValue)
            {
                <dt class="col-sm-3">Renews</dt>
                <dd class="col-sm-9">@billing.SubscriptionPeriodEnd.Value.ToString("d")</dd>
            }
        </dl>
    </div>

    @if (billing.IsTrialActive && billing.TrialEndsAt.HasValue)
    {
        <div class="alert alert-info">Trial active until @billing.TrialEndsAt.Value.ToString("d").</div>
    }

    @if (billing.IsTrialExpired)
    {
        <div class="alert alert-danger" role="alert">Your trial has expired. Upgrade to restore access.</div>
    }

    @if (billing.IsOverLimit)
    {
        <div class="alert alert-warning" role="alert">Usage exceeds plan limits. Upgrade to continue scaling.</div>
    }

    @if (isolation is not null && isolation.IsolationEnabled)
    {
        <div class="card-panel p-4 mb-4">
            <h2 class="h5 mb-3">Data isolation</h2>
            <dl class="row mb-3">
                <dt class="col-sm-3">Mode</dt>
                <dd class="col-sm-9">@isolation.IsolationMode</dd>
                @if (!string.IsNullOrWhiteSpace(isolation.DatabaseSchemaName))
                {
                    <dt class="col-sm-3">Schema</dt>
                    <dd class="col-sm-9"><code>@isolation.DatabaseSchemaName</code></dd>
                }
                <dt class="col-sm-3">Provisioned</dt>
                <dd class="col-sm-9">@(isolation.IsSchemaProvisioned ? isolation.SchemaProvisionedAt?.ToString("g") ?? "Yes" : "No")</dd>
            </dl>
            @if (!isolation.IsSchemaProvisioned)
            {
                <form method="post" asp-page-handler="ProvisionSchema">
                    <button type="submit" class="btn btn-outline-primary">Provision dedicated schema</button>
                </form>
                <p class="small text-muted mt-2 mb-0">Recommended for regulated workloads and EU data residency.</p>
            }
        </div>
    }

    @if (billing.StripeEnabled)
    {
        <div class="card-panel p-4">
            <h2 class="h5 mb-3">Upgrade plan</h2>
            <p class="text-muted mb-3">Checkout is powered by Stripe. You will be redirected to complete payment.</p>
            <div class="d-flex flex-wrap gap-2">
                @if (billing.Plan != "Team" && billing.Plan != "Enterprise")
                {
                    <form method="post" asp-page-handler="CheckoutTeam">
                        <button type="submit" class="btn btn-primary">Upgrade to Team</button>
                    </form>
                    <form method="post" asp-page-handler="CheckoutEnterprise">
                        <button type="submit" class="btn btn-outline-primary">Upgrade to Enterprise</button>
                    </form>
                }
                @if (billing.HasActiveSubscription || billing.Plan is "Team" or "Enterprise")
                {
                    <form method="post" asp-page-handler="Portal">
                        <button type="submit" class="btn btn-outline-secondary">Manage billing</button>
                    </form>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-secondary">Stripe billing is not configured in this environment.</div>
    }
}
else
{
    <div class="card-panel p-4">
        <p class="mb-2">Platform administrator view — no tenant context on this account.</p>
        @if (Model.AllTenants.Count > 0)
        {
            <table class="table table-sm">
                <thead><tr><th>Name</th><th>Slug</th><th>Plan</th><th>Region</th></tr></thead>
                <tbody>
                @foreach (var t in Model.AllTenants)
                {
                    <tr><td>@t.Name</td><td>@t.Slug</td><td>@t.Plan</td><td>@t.Region</td></tr>
                }
                </tbody>
            </table>
        }
    </div>
}
