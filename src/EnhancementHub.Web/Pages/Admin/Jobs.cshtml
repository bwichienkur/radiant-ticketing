@page
@model EnhancementHub.Web.Pages.Admin.JobsModel
@{
    ViewData["AdminSection"] = "jobs";
    ViewData["Title"] = "Background Jobs";
    var status = Model.Status;
}

<partial name="_AdminNav" />

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
        <h1>Background Jobs</h1>
        <p>Queue depth, schedules, and failed job recovery</p>
    </div>
    @if (status is not null)
    {
        <span class="badge text-bg-secondary badge-status">Provider: @status.Provider</span>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (status is null)
{
    <div class="card-panel p-4">
        <p class="text-muted mb-0">Unable to load job status.</p>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="stat-card"><div class="label">Pending Indexing</div><div class="value">@status.QueueCounts.PendingRepositoryIndexing</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="label">Awaiting AI Analysis</div><div class="value">@status.QueueCounts.AwaitingAiAnalysis</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="label">Discovery Queued</div><div class="value">@status.QueueCounts.QueuedApplicationDiscovery</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="label">Schema Scans Pending</div><div class="value">@status.QueueCounts.PendingDatabaseSchemaScans</div></div></div>
    </div>

    @if (Model.Freshness is not null)
    {
        var freshness = Model.Freshness;
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="label">Index freshness (@freshness.SlaHours h SLA)</div>
                    <div class="value fs-4">@freshness.FreshnessPercent<span class="fs-6">%</span></div>
                </div>
            </div>
            <div class="col-md-3"><div class="stat-card"><div class="label">Fresh repositories</div><div class="value">@freshness.FreshCount / @freshness.TotalRepositories</div></div></div>
            <div class="col-md-3"><div class="stat-card"><div class="label">Stale repositories</div><div class="value text-warning">@freshness.StaleCount</div></div></div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="label">SLA status</div>
                    <div class="value fs-5 @(freshness.SlaMet ? "text-success" : "text-danger")">@(freshness.SlaMet ? "Met" : "Missed")</div>
                </div>
            </div>
        </div>

        @if (freshness.StaleRepositories.Count > 0)
        {
            <div class="card-panel mb-4">
                <div class="card-header px-0">Stale repositories (top @freshness.StaleRepositories.Count)</div>
                <div class="table-responsive">
                    <table class="table table-enterprise mb-0">
                        <thead><tr><th scope="col">Repository</th><th scope="col">Application</th><th scope="col">Last indexed</th><th scope="col">Hours stale</th><th scope="col">Status</th></tr></thead>
                        <tbody>
                        @foreach (var repo in freshness.StaleRepositories)
                        {
                            <tr>
                                <td>@repo.Name</td>
                                <td>@(repo.ApplicationName ?? "—")</td>
                                <td class="small">@(repo.LastIndexedAt?.ToString("u") ?? "Never")</td>
                                <td>@(repo.HoursSinceIndexed?.ToString("0.#") ?? "—")</td>
                                <td>@repo.IndexingStatus</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

    @if (status.Hangfire is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-2"><div class="stat-card"><div class="label">Enqueued</div><div class="value fs-5">@status.Hangfire.Enqueued</div></div></div>
            <div class="col-md-2"><div class="stat-card"><div class="label">Processing</div><div class="value fs-5">@status.Hangfire.Processing</div></div></div>
            <div class="col-md-2"><div class="stat-card"><div class="label">Scheduled</div><div class="value fs-5">@status.Hangfire.Scheduled</div></div></div>
            <div class="col-md-2"><div class="stat-card"><div class="label">Succeeded</div><div class="value fs-5 text-success">@status.Hangfire.Succeeded</div></div></div>
            <div class="col-md-2"><div class="stat-card"><div class="label">Failed</div><div class="value fs-5 text-danger">@status.Hangfire.Failed</div></div></div>
            <div class="col-md-2"><div class="stat-card"><div class="label">Deleted</div><div class="value fs-5">@status.Hangfire.Deleted</div></div></div>
        </div>
    }
    else if (status.Provider.Equals("Hangfire", StringComparison.OrdinalIgnoreCase))
    {
        <div class="alert alert-warning">
            Hangfire statistics are unavailable from this process. View the Worker dashboard at <code>/hangfire</code> in Development, or ensure the API has Hangfire monitoring storage configured.
        </div>
    }

    <div class="card-panel mb-4">
        <div class="card-header px-0">Scheduled jobs</div>
        <div class="table-responsive">
            <table class="table table-enterprise mb-0">
                <thead><tr><th scope="col">Job</th><th scope="col">Description</th><th scope="col">Schedule</th><th scope="col">Last run</th><th scope="col">Next run</th></tr></thead>
                <tbody>
                @foreach (var job in status.Jobs)
                {
                    <tr>
                        <td><code>@job.JobId</code></td>
                        <td>@job.Description</td>
                        <td>@job.Schedule</td>
                        <td>@(job.LastExecution ?? "—")</td>
                        <td>@(job.NextExecution ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-panel">
        <div class="card-header px-0 d-flex justify-content-between align-items-center">
            <span>Failed jobs</span>
            @if (!status.Provider.Equals("Hangfire", StringComparison.OrdinalIgnoreCase))
            {
                <span class="small text-muted">Manual retry requires Hangfire</span>
            }
        </div>
        @if (status.FailedJobs.Count == 0)
        {
            <p class="text-muted mb-0 p-3">No failed jobs recorded.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-enterprise mb-0">
                    <thead><tr><th scope="col">Job ID</th><th scope="col">Name</th><th scope="col">Failed at</th><th scope="col">Error</th><th scope="col"></th></tr></thead>
                    <tbody>
                    @foreach (var failed in status.FailedJobs)
                    {
                        <tr>
                            <td><code class="small">@failed.JobId</code></td>
                            <td class="small">@(failed.JobName ?? "—")</td>
                            <td class="small">@(failed.FailedAt ?? "—")</td>
                            <td class="small text-muted">@(failed.ExceptionMessage ?? "—")</td>
                            <td>
                                @if (status.Provider.Equals("Hangfire", StringComparison.OrdinalIgnoreCase))
                                {
                                    <form method="post" asp-page-handler="Retry" class="d-inline">
                                        <input type="hidden" name="jobId" value="@failed.JobId" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Retry</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <p class="text-muted small mt-3 mb-0">Last updated @status.GeneratedAtUtc.ToString("u") UTC</p>
}
