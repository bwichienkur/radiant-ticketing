@model EnhancementHub.Web.Pages.Onboarding.WizardModel

@{
    var current = (int)Model.Session.CurrentStep;
}

<div class="onboarding-progress mb-4">
    <div class="d-flex justify-content-between flex-wrap gap-2">
        @foreach (var step in WizardModel.StepDefinitions)
        {
            var isActive = step.Number == current;
            var isComplete = step.Number < current || Model.Session.Status == EnhancementHub.Domain.Enums.OnboardingSessionStatus.Completed;
            var canNavigate = step.Number <= current && Model.Session.Status != EnhancementHub.Domain.Enums.OnboardingSessionStatus.Completed;
            <div class="onboarding-step @(isActive ? "active" : null) @(isComplete ? "complete" : null)" @(isActive ? Html.Raw("aria-current=\"step\"") : null)>
                @if (canNavigate && !isActive)
                {
                    <a asp-page="./Wizard" asp-route-id="@Model.Session.Id" asp-route-step="@step.Number" class="step-link">
                        <div class="step-number">@(isComplete ? "✓" : step.Number.ToString())</div>
                        <div class="step-label">@step.Label</div>
                    </a>
                }
                else
                {
                    <div class="step-number">@(isComplete && !isActive ? "✓" : step.Number.ToString())</div>
                    <div class="step-label">@step.Label</div>
                }
            </div>
        }
    </div>
</div>
