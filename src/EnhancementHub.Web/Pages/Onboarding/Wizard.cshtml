@page "{id:guid?}"
@model EnhancementHub.Web.Pages.Onboarding.WizardModel
@{
    ViewData["Title"] = "Application Setup Wizard";
    var steps = WizardModel.StepDefinitions;
}

<div class="page-header">
    <h1>Document your application</h1>
    <p class="text-muted">Guided setup to connect code, scan databases, and generate architecture documentation.</p>
</div>

@if (Model.Session.Status == EnhancementHub.Domain.Enums.OnboardingSessionStatus.InProgress && Model.Session.CurrentStep != EnhancementHub.Domain.Enums.OnboardingStep.Complete)
{
    <div class="alert alert-light border mb-3">
        <strong>Resume setup</strong> — you're on step @((int)Model.Session.CurrentStep) (@WizardModel.StepDefinitions.First(s => s.Number == (int)Model.Session.CurrentStep).Label).
        @if (!string.IsNullOrWhiteSpace(Model.Session.ApplicationName))
        {
            <span>Application: <strong>@Model.Session.ApplicationName</strong>.</span>
        }
        Progress is saved automatically as you complete each step.
    </div>
}

<partial name="_OnboardingProgress" model="Model" />

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger d-flex justify-content-between align-items-start gap-3">
        <div>
            <strong>Something went wrong</strong>
            <div class="mt-1">@Model.ErrorMessage</div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

<div class="card-panel p-4">
    @switch (Model.Session.CurrentStep)
    {
        case EnhancementHub.Domain.Enums.OnboardingStep.ApplicationBasics:
            <h2 class="h4 mb-3">Step 1 — Application basics</h2>
            <p class="text-muted">Tell us about the application you want to document.</p>
            <form method="post" asp-page-handler="Step1">
                <input type="hidden" asp-for="SessionId" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Application name</label>
                        <input asp-for="Step1.Name" class="form-control" placeholder="e.g. Order Management System" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Business domain</label>
                        <input asp-for="Step1.BusinessDomain" class="form-control" placeholder="e.g. E-Commerce" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Purpose</label>
                        <textarea asp-for="Step1.Purpose" class="form-control" rows="2" placeholder="What does this application do?"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Risk-sensitive areas</label>
                        <input asp-for="Step1.RiskSensitiveAreas" class="form-control" placeholder="e.g. PII, payments, authentication" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Owning team (optional)</label>
                        <input asp-for="Step1.OwnerTeamName" class="form-control" placeholder="e.g. Platform Engineering" />
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Continue to code connection</button>
                </div>
            </form>
            break;

        case EnhancementHub.Domain.Enums.OnboardingStep.ConnectCode:
            <h2 class="h4 mb-3">Step 2 — Connect code</h2>
            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#local-path-tab" type="button">Local path</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#git-clone-tab" type="button">Clone from Git</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#github-app-tab" type="button">GitHub App</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#zip-upload-tab" type="button">Upload ZIP</button></li>
            </ul>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="local-path-tab">
                    <p class="text-muted">Point to a local clone of the repository. EnhancementHub scans it read-only.</p>
                    <form method="post" asp-page-handler="ValidatePath" class="mb-4">
                        <input type="hidden" asp-for="SessionId" />
                        <div class="mb-3">
                            <label class="form-label">Repository path</label>
                            <div class="input-group">
                                <input asp-for="Step2.RepositoryPath" class="form-control" placeholder="/path/to/repo" />
                                <button type="submit" class="btn btn-outline-secondary">Test access</button>
                            </div>
                        </div>
                    </form>
                    @if (Model.PathValidation is not null)
                    {
                        <div class="alert @(Model.PathValidation.IsValid ? "alert-success" : "alert-warning")">
                            @if (Model.PathValidation.IsValid)
                            {
                                <div>Path is accessible.</div>
                                <div class="small mt-1">
                                    @Model.PathValidation.CSharpFileCount C# files ·
                                    @Model.PathValidation.ControllerCount controllers ·
                                    @Model.PathValidation.DbContextCount DbContexts ·
                                    @Model.PathValidation.EntityMappingCount entity mappings
                                </div>
                            }
                            else
                            {
                                <div>@Model.PathValidation.ErrorMessage</div>
                            }
                        </div>
                    }
                    <form method="post" asp-page-handler="Step2">
                        <input type="hidden" asp-for="SessionId" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Repository name</label>
                                <input asp-for="Step2.RepositoryName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Default branch</label>
                                <input asp-for="Step2.DefaultBranch" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Repository path</label>
                                <input asp-for="Step2.RepositoryPath" class="form-control" />
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Continue to database</button>
                            <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="1" class="btn btn-outline-secondary">Back</a>
                        </div>
                    </form>
                </div>
                <div class="tab-pane fade" id="git-clone-tab">
                    <p class="text-muted">Clone a remote repository to the EnhancementHub workspace (requires git on the server).</p>
                    <form method="post" asp-page-handler="CloneGit">
                        <input type="hidden" asp-for="SessionId" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Repository name</label>
                                <input asp-for="Step2Git.RepositoryName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Branch</label>
                                <input asp-for="Step2Git.DefaultBranch" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Git URL</label>
                                <input asp-for="Step2Git.RepositoryUrl" class="form-control" placeholder="https://github.com/org/repo.git" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Access token (optional, for private repos)</label>
                                <input asp-for="Step2Git.AccessToken" class="form-control" type="password" autocomplete="off" />
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Clone & continue</button>
                            <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="1" class="btn btn-outline-secondary">Back</a>
                        </div>
                    </form>
                </div>
                <div class="tab-pane fade" id="github-app-tab">
                    <p class="text-muted">Clone private repositories using a configured GitHub App installation (enterprise-friendly).</p>
                    @if (Model.GitHubAppStatus is { IsConfigured: false })
                    {
                        <div class="alert alert-warning">
                            GitHub App is not configured. Set <code>GitHubApp:AppId</code>, <code>GitHubApp:PrivateKey</code>, and <code>GitHubApp:InstallationId</code> in appsettings.
                        </div>
                    }
                    <form method="post" asp-page-handler="CloneGitHubApp">
                        <input type="hidden" asp-for="SessionId" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Repository name</label>
                                <input asp-for="Step2GitHubApp.RepositoryName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Branch</label>
                                <input asp-for="Step2GitHubApp.DefaultBranch" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Owner</label>
                                <input asp-for="Step2GitHubApp.Owner" class="form-control" placeholder="organization-or-user" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Repository</label>
                                <input asp-for="Step2GitHubApp.Repository" class="form-control" placeholder="repo-name" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Installation ID (optional override)</label>
                                <input asp-for="Step2GitHubApp.InstallationId" class="form-control" placeholder="@(Model.GitHubAppStatus?.DefaultInstallationId?.ToString() ?? "uses appsettings default")" />
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@(Model.GitHubAppStatus is { IsConfigured: false })">Clone via GitHub App</button>
                            <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="1" class="btn btn-outline-secondary">Back</a>
                        </div>
                    </form>
                </div>
                <div class="tab-pane fade" id="zip-upload-tab">
                    <p class="text-muted">Upload a ZIP archive for air-gapped environments where Git access is unavailable.</p>
                    <form method="post" asp-page-handler="UploadZip" enctype="multipart/form-data">
                        <input type="hidden" asp-for="SessionId" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Repository name</label>
                                <input asp-for="Step2.RepositoryName" class="form-control" placeholder="Defaults to archive filename" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">ZIP archive</label>
                                <input type="file" name="zipFile" class="form-control" accept=".zip,application/zip" />
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Upload & continue</button>
                            <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="1" class="btn btn-outline-secondary">Back</a>
                        </div>
                    </form>
                </div>
            </div>
            break;

        case EnhancementHub.Domain.Enums.OnboardingStep.ConnectDatabase:
            <h2 class="h4 mb-3">Step 3 — Connect database</h2>
            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#direct-db-tab" type="button">Direct connection</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#onprem-agent-tab" type="button">On-prem agent</button></li>
            </ul>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="direct-db-tab">
                    <p class="text-muted">Register a read-only database connection.</p>
                    <form method="post" asp-page-handler="BuildConnectionString" class="card-panel p-3 mb-4">
                        <input type="hidden" asp-for="SessionId" />
                        <h3 class="h6">Connection string builder</h3>
                        <div class="row g-3 mt-1">
                            <div class="col-md-4">
                                <label class="form-label">Provider</label>
                                <select asp-for="Step3Builder.Provider" class="form-select" asp-items="Html.GetEnumSelectList<EnhancementHub.Domain.Enums.DatabaseProviderType>()"></select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Host</label>
                                <input asp-for="Step3Builder.Host" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Port</label>
                                <input asp-for="Step3Builder.Port" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Database</label>
                                <input asp-for="Step3Builder.Database" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Username</label>
                                <input asp-for="Step3Builder.Username" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Password</label>
                                <input asp-for="Step3Builder.Password" class="form-control" type="password" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-outline-secondary btn-sm mt-3">Build connection string</button>
                    </form>
                    <form method="post" asp-page-handler="Step3">
                        <input type="hidden" asp-for="SessionId" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Connection name</label>
                                <input asp-for="Step3.ConnectionName" class="form-control" placeholder="e.g. Production read replica" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Provider</label>
                                <select asp-for="Step3.Provider" class="form-select" asp-items="Html.GetEnumSelectList<EnhancementHub.Domain.Enums.DatabaseProviderType>()"></select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Connection string</label>
                                <textarea asp-for="Step3.ConnectionString" class="form-control" rows="3"></textarea>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input asp-for="Step3.IsReadOnly" class="form-check-input" />
                                    <label asp-for="Step3.IsReadOnly" class="form-check-label">Read-only connection</label>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-primary">Register & continue</button>
                            <button type="submit" asp-page-handler="SkipDatabase" class="btn btn-outline-secondary">Skip database for now</button>
                            <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="2" class="btn btn-link">Back</a>
                        </div>
                    </form>
                </div>
                <div class="tab-pane fade" id="onprem-agent-tab">
                    <p class="text-muted">For air-gapped databases, register an on-prem agent and run it inside the client network.</p>
                    @if (Model.OnPremSetup is not null)
                    {
                        <div class="alert alert-success">
                            <div class="fw-semibold">Agent registered</div>
                            <div class="small mt-2">Agent ID: @Model.OnPremSetup.AgentId</div>
                            <div class="small">Connection ID: @Model.OnPremSetup.ConnectionId</div>
                        </div>
                        <pre class="bg-dark text-light p-3 rounded small">@Model.OnPremSetup.AgentConfigSnippet</pre>
                        <p class="text-muted small">Run: <code>@Model.OnPremSetup.RunCommand</code></p>
                        <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="4" class="btn btn-primary">Continue to discovery</a>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="SetupOnPremAgent">
                            <input type="hidden" asp-for="SessionId" />
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Connection name</label>
                                    <input asp-for="Step3.ConnectionName" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Provider</label>
                                    <select asp-for="Step3.Provider" class="form-select" asp-items="Html.GetEnumSelectList<EnhancementHub.Domain.Enums.DatabaseProviderType>()"></select>
                                </div>
                            </div>
                            <div class="mt-4 d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Register on-prem agent</button>
                                <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="2" class="btn btn-link">Back</a>
                            </div>
                        </form>
                    }
                </div>
            </div>
            break;

        case EnhancementHub.Domain.Enums.OnboardingStep.RunDiscovery:
            <h2 class="h4 mb-3">Step 4 — Run discovery</h2>
            <p class="text-muted">Index code, scan databases, build the system graph, and check schema drift.</p>
            @if (!string.IsNullOrWhiteSpace(Model.Session.DiscoveryStatus))
            {
                <div class="alert @(Model.Session.DiscoveryJobState == EnhancementHub.Domain.Enums.DiscoveryJobState.Failed ? "alert-warning" : "alert-info")">
                    <div>@Model.Session.DiscoveryStatus</div>
                    <div class="small text-muted mt-1">State: @Model.Session.DiscoveryJobState</div>
                </div>
            }
            @if (Model.Session.DiscoveryJobState == EnhancementHub.Domain.Enums.DiscoveryJobState.Failed)
            {
                <div class="card-panel p-3 mb-3">
                    <h3 class="h6">Recovery steps</h3>
                    <ol class="small mb-3">
                        <li>Verify the repository path is still accessible and the database connection is valid.</li>
                        <li>Check Worker logs if discovery runs in a background job host.</li>
                        <li>Fix the issue, then click <strong>Retry discovery</strong> below.</li>
                    </ol>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="2" class="btn btn-sm btn-outline-secondary">Review code connection</a>
                        <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="3" class="btn btn-sm btn-outline-secondary">Review database connection</a>
                    </div>
                </div>
            }
            <form method="post" asp-page-handler="Step4">
                <input type="hidden" asp-for="SessionId" />
                <button type="submit" class="btn btn-primary" disabled="@(Model.Session.DiscoveryJobState is EnhancementHub.Domain.Enums.DiscoveryJobState.Queued or EnhancementHub.Domain.Enums.DiscoveryJobState.Running)">
                    @(Model.Session.DiscoveryJobState == EnhancementHub.Domain.Enums.DiscoveryJobState.Failed ? "Retry discovery" : Model.Session.DiscoveryCompletedAt is null ? "Queue discovery" : "Re-queue discovery")
                </button>
                @if (Model.Session.DiscoveryJobState == EnhancementHub.Domain.Enums.DiscoveryJobState.Completed)
                {
                    <a asp-page="./Wizard" asp-route-id="@Model.SessionId" asp-route-step="5" class="btn btn-outline-primary ms-2">Continue to review</a>
                }
            </form>
            @if (Model.Session.DiscoveryJobState is EnhancementHub.Domain.Enums.DiscoveryJobState.Queued or EnhancementHub.Domain.Enums.DiscoveryJobState.Running)
            {
                <div class="mt-3 d-flex align-items-center gap-2 text-muted">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span>Discovery in progress — this page refreshes every 4 seconds.</span>
                </div>
                <script>
                    setTimeout(() => window.location.reload(), 4000);
                </script>
            }
            break;

        case EnhancementHub.Domain.Enums.OnboardingStep.ReviewExport:
            <h2 class="h4 mb-3">Step 5 — Review & export</h2>
            @if (Model.Review is not null)
            {
                <div class="row g-3 mb-4">
                    <div class="col-md-3"><div class="stat-card"><div class="label">Repositories</div><div class="value fs-3">@Model.Review.RepositoryCount</div></div></div>
                    <div class="col-md-3"><div class="stat-card"><div class="label">Databases</div><div class="value fs-3">@Model.Review.DatabaseConnectionCount</div></div></div>
                    <div class="col-md-3"><div class="stat-card"><div class="label">Graph nodes</div><div class="value fs-3">@Model.Review.GraphNodeCount</div></div></div>
                    <div class="col-md-3"><div class="stat-card"><div class="label">Drift findings</div><div class="value fs-3">@Model.Review.DriftFindingCount</div></div></div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Review.LatestProfileSummary))
                {
                    <p class="text-muted">@Model.Review.LatestProfileSummary</p>
                }
            }
            <div class="d-flex gap-2 flex-wrap">
                <form method="post" asp-page-handler="ExportDocs" class="d-inline">
                    <input type="hidden" asp-for="SessionId" />
                    <button type="submit" class="btn btn-primary">Download documentation</button>
                </form>
                <a asp-page="/SystemMap/Index" asp-route-applicationId="@Model.Session.ApplicationId" class="btn btn-outline-primary">View system map</a>
                <a asp-page="/SchemaDrift/Index" class="btn btn-outline-secondary">Review drift</a>
                <form method="post" asp-page-handler="Complete" class="d-inline">
                    <input type="hidden" asp-for="SessionId" />
                    <button type="submit" class="btn btn-success">Finish setup</button>
                </form>
            </div>
            break;

        case EnhancementHub.Domain.Enums.OnboardingStep.Complete:
            <div class="text-center py-4">
                <h2 class="h4 mb-3">Setup complete</h2>
                <p class="text-muted mb-4">@Model.Session.ApplicationName is ready. You can submit enhancement requests, monitor drift, and re-export documentation anytime.</p>
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a asp-page="/Applications/Details" asp-route-id="@Model.Session.ApplicationId" class="btn btn-primary">View application</a>
                    <a asp-page="/Documentation/Export" class="btn btn-outline-primary">Export docs</a>
                    <a asp-page="/Index" class="btn btn-outline-secondary">Go to dashboard</a>
                </div>
            </div>
            break;
    }
</div>
