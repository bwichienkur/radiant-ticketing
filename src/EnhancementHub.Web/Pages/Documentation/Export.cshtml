@page
@model EnhancementHub.Web.Pages.Documentation.ExportModel
@{ ViewData["Title"] = "Export Documentation"; }

<h1 class="h3 mb-4">Export system documentation</h1>

<form method="post" class="col-lg-6">
    <div class="mb-3">
        <label class="form-label">Application</label>
        <select asp-for="ApplicationId" class="form-select">
            @foreach (var app in Model.Applications)
            {
                <option value="@app.Id">@app.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Format</label>
        <select asp-for="Format" class="form-select" asp-items="Html.GetEnumSelectList<EnhancementHub.Domain.Enums.DocumentationExportFormat>()"></select>
    </div>
    <button class="btn btn-primary">Export</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Preview))
{
    <div class="card mt-4"><div class="card-header">Preview</div><pre class="card-body">@Model.Preview</pre></div>
}
