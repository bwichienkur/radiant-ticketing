@page "{id:guid}"
@model EnhancementHub.Web.Pages.DatabaseConnections.DetailsModel
@{
    ViewData["Title"] = Model.Schema?.ConnectionName ?? "Database";
    ViewData["PageHeaderTitle"] = Model.Schema?.ConnectionName ?? "Database connection";
    ViewData["PageHeaderDescription"] = "Schema details and column metadata";
}

<header class="page-header d-flex justify-content-between align-items-start flex-wrap gap-3">
    <partial name="_PageHeader" />
    <div class="page-header-actions d-flex flex-wrap gap-2">
        <a class="btn btn-outline-primary btn-sm" asp-page="Erd" asp-route-id="@Model.ConnectionId">View ERD</a>
        <a class="btn btn-outline-secondary btn-sm" asp-page="/SchemaDrift/Index" asp-route-connectionId="@Model.ConnectionId">Drift report</a>
    </div>
</header>

@if (Model.Schema is not null)
{
    @foreach (var table in Model.Schema.Tables)
    {
        <div class="card-panel mb-3">
            <div class="card-header eh-section-title px-3 py-3">@table.SchemaName.@table.TableName</div>
            <div class="table-responsive">
                <table class="table table-sm table-enterprise mb-0">
                    <thead><tr><th scope="col">Column</th><th scope="col">Type</th><th scope="col">Nullable</th><th scope="col">PK</th><th scope="col">FK</th></tr></thead>
                    <tbody>
                    @foreach (var col in table.Columns)
                    {
                        <tr>
                            <td>@col.Name</td>
                            <td>@col.DataType</td>
                            <td>@(col.IsNullable ? "Yes" : "No")</td>
                            <td>@(col.IsPrimaryKey ? "✓" : "")</td>
                            <td>@(col.IsForeignKey ? "✓" : "")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else
{
    ViewData["EmptyStateTitle"] = "Schema not available";
    ViewData["EmptyStateDescription"] = "Run a scan from the database connections list to populate schema details.";
    ViewData["EmptyStateIcon"] = "inbox";
    ViewData["EmptyStateActionUrl"] = "/DatabaseConnections/Index";
    ViewData["EmptyStateActionText"] = "Back to connections";
    <partial name="_EmptyState" />
}
