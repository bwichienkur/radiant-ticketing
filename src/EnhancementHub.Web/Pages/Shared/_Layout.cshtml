<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <script>
        (function () {
            try {
                var stored = localStorage.getItem('eh-theme');
                var theme = stored === 'Light' ? 'light'
                    : stored === 'Dark' ? 'dark'
                    : stored === 'light' || stored === 'dark' ? stored
                    : 'dark';
                document.documentElement.setAttribute('data-bs-theme', theme);
            } catch (e) { /* ignore */ }
        })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnhancementHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/eh-premium-v3.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/eh-enterprise-v4.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="app-shell">
            <partial name="_SidebarNav" />
            <div class="app-main">
                <partial name="_AppTopBar" />
                <main id="main-content" class="app-content" tabindex="-1">
                    @RenderBody()
                </main>
            </div>
        </div>

        <div class="offcanvas offcanvas-start app-sidebar-offcanvas" tabindex="-1" id="appSidebarOffcanvas" aria-labelledby="appSidebarOffcanvasLabel">
            <div class="offcanvas-header border-bottom">
                <h2 class="offcanvas-title h6 mb-0" id="appSidebarOffcanvasLabel">Navigation</h2>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close navigation"></button>
            </div>
            <div class="offcanvas-body p-0">
                <partial name="_SidebarNav" />
            </div>
        </div>
    }
    else
    {
        <main id="main-content" tabindex="-1">
            @RenderBody()
        </main>
    }

    <div id="notification-toast-container" class="toast-container position-fixed bottom-0 end-0 p-3"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    }
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
