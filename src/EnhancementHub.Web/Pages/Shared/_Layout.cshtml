<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnhancementHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand fw-semibold" asp-page="/Index">EnhancementHub</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/EnhancementRequests/Index">Requests</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/EnhancementRequests/Approve">Approvals</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Applications/Index">Applications</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Repositories/Index">Repositories</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Audit/Index">Audit</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Admin</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Admin/Settings">Settings</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/AiPrompts">AI Prompts</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <span class="navbar-text text-white-50 me-3">@User.Identity.Name</span>
                    <form method="post" asp-page="/Account/Login" asp-page-handler="Logout" class="d-inline">
                        <button type="submit" class="btn btn-outline-light btn-sm">Sign out</button>
                    </form>
                }
            </div>
        </div>
    </nav>

    <main class="container-fluid py-4 px-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
