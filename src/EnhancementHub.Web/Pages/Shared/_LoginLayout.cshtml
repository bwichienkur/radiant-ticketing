<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <script>
        (function () {
            try {
                var stored = localStorage.getItem('eh-theme');
                var theme = stored === 'Light' ? 'light'
                    : stored === 'Dark' ? 'dark'
                    : stored === 'light' || stored === 'dark' ? stored
                    : 'dark';
                document.documentElement.setAttribute('data-bs-theme', theme);
            } catch (e) { /* ignore */ }
        })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnhancementHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/eh-premium-v3.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/eh-enterprise-v4.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="login-body">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="login-theme-segmented eh-segmented-control" role="group" aria-label="Theme preference">
        <button type="button" class="eh-segmented-option" data-theme-preference="System">System</button>
        <button type="button" class="eh-segmented-option" data-theme-preference="Light">Light</button>
        <button type="button" class="eh-segmented-option active" data-theme-preference="Dark">Dark</button>
    </div>
    <main id="main-content" tabindex="-1">
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
