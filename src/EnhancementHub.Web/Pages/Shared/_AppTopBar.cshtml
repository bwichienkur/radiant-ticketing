@{
    var title = ViewData["Title"]?.ToString() ?? "EnhancementHub";
    var breadcrumb = ViewData["Breadcrumb"] as string;
}

<header class="app-topbar">
    <div class="topbar-left">
        <button type="button" class="btn btn-outline-secondary btn-sm sidebar-toggle-btn" data-sidebar-toggle aria-label="Toggle sidebar">
            <svg class="topbar-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
        <nav class="topbar-breadcrumb" aria-label="Breadcrumb">
            <a asp-page="/Index">Home</a>
            <span aria-hidden="true">›</span>
            <span id="eh-topbar-crumb-section" class="topbar-breadcrumb-section">@(breadcrumb ?? "Home")</span>
            <span aria-hidden="true">›</span>
            <span id="eh-topbar-crumb-current" aria-current="page">@(breadcrumb ?? title)</span>
        </nav>
    </div>
    <div class="topbar-actions">
        <button type="button" class="btn btn-outline-secondary btn-sm eh-omnibox-trigger" data-command-trigger aria-label="Open command palette (Ctrl+K or Cmd+K)">
            <svg class="topbar-icon-svg me-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <path d="m20 20-3.5-3.5" />
            </svg>
            <span class="d-none d-md-inline">Search</span>
            <kbd class="command-kbd" data-command-kbd>⌘K</kbd>
        </button>
        <div id="eh-topbar-theme-slot" class="topbar-theme-slot"></div>
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm position-relative topbar-icon-btn" type="button" data-bs-toggle="dropdown" aria-label="Notifications">
                <svg class="topbar-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
                <span id="notification-badge" class="notification-badge d-none">0</span>
            </button>
            <div class="dropdown-menu dropdown-menu-end notification-panel p-0">
                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                    <strong class="small">Notifications</strong>
                    <button type="button" class="btn btn-link btn-sm p-0" id="notification-mark-read">Mark all read</button>
                </div>
                <div id="notification-list" class="notification-list"></div>
                <div class="border-top px-3 py-2">
                    <a href="/Spa/Account/Notifications" class="small">Notification preferences</a>
                </div>
            </div>
        </div>
        <span class="topbar-user d-none d-md-inline" id="eh-topbar-username">@User.Identity?.Name</span>
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-label="Account menu">
                Account
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><h6 class="dropdown-header">@User.Identity?.Name</h6></li>
                <li><a class="dropdown-item" href="/Spa/Account/Notifications">Notification preferences</a></li>
                @if (User.IsInRole("Admin"))
                {
                    <li><a class="dropdown-item" href="/Spa/Settings/General">Settings</a></li>
                }
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form method="post" asp-page="/Account/Login" asp-page-handler="Logout" class="px-3 py-1">
                        <button type="submit" class="btn btn-link btn-sm text-danger p-0">Sign out</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</header>
