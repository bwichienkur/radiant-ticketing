@{
    var title = ViewData["Title"]?.ToString() ?? "EnhancementHub";
    var breadcrumb = ViewData["Breadcrumb"] as string;
    var userName = User.Identity?.Name ?? "User";
    var nameParts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = nameParts.Length >= 2
        ? $"{char.ToUpper(nameParts[0][0])}{char.ToUpper(nameParts[^1][0])}"
        : userName.Length >= 2
            ? userName[..2].ToUpperInvariant()
            : userName.ToUpperInvariant();
}

<header class="app-topbar eh-topbar">
    <div class="eh-topbar-start">
        <button type="button" class="eh-topbar-icon-btn sidebar-toggle-btn" data-sidebar-toggle aria-label="Toggle sidebar">
            <svg class="topbar-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
        <nav class="eh-topbar-breadcrumb topbar-breadcrumb" aria-label="Breadcrumb">
            <a asp-page="/Index">Home</a>
            <span class="eh-topbar-breadcrumb-sep" aria-hidden="true">/</span>
            <span id="eh-topbar-crumb-section" class="topbar-breadcrumb-section">@(breadcrumb ?? "Home")</span>
            <span class="eh-topbar-breadcrumb-sep" aria-hidden="true">/</span>
            <span id="eh-topbar-crumb-current" class="eh-topbar-breadcrumb-current" aria-current="page">@(breadcrumb ?? title)</span>
        </nav>
    </div>
    <div class="eh-topbar-end topbar-actions">
        <button type="button" class="eh-topbar-search eh-omnibox-trigger" data-command-trigger aria-label="Open command palette (Ctrl+K or Cmd+K)">
            <svg class="eh-topbar-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <path d="m20 20-3.5-3.5" />
            </svg>
            <span class="eh-topbar-search-label">Search…</span>
            <kbd class="eh-kbd command-kbd" data-command-kbd>⌘K</kbd>
        </button>
        <div id="eh-topbar-theme-slot" class="eh-topbar-theme topbar-theme-slot"></div>
        <div class="dropdown eh-topbar-dropdown">
            <button class="eh-topbar-icon-btn position-relative" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-label="Notifications">
                <svg class="topbar-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
                <span id="notification-badge" class="notification-badge d-none">0</span>
            </button>
            <div class="dropdown-menu dropdown-menu-end eh-dropdown-panel notification-panel">
                <div class="eh-dropdown-header">
                    <strong>Notifications</strong>
                    <button type="button" class="eh-dropdown-link-btn" id="notification-mark-read">Mark all read</button>
                </div>
                <div id="notification-list" class="notification-list"></div>
                <div class="eh-dropdown-footer">
                    <a href="/Spa/Account/Notifications">Notification preferences</a>
                </div>
            </div>
        </div>
        <div class="dropdown eh-topbar-dropdown">
            <button class="eh-topbar-user-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-auto-close="true" aria-expanded="false" aria-label="Account menu">
                <span class="eh-topbar-avatar" aria-hidden="true">@initials</span>
                <span class="eh-topbar-user-name d-none d-lg-inline">@userName</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end eh-dropdown-panel">
                <li><h6 class="dropdown-header">@userName</h6></li>
                <li><a class="dropdown-item" href="/Spa/Account/Notifications">Notification preferences</a></li>
                @if (User.IsInRole("Admin"))
                {
                    <li><a class="dropdown-item" href="/Spa/Settings/General">Settings</a></li>
                }
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form method="post" asp-page="/Account/Login" asp-page-handler="Logout" class="eh-dropdown-signout">
                        <button type="submit" class="dropdown-item text-danger">Sign out</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</header>
