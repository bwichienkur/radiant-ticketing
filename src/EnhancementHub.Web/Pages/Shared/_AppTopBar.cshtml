@{
    var userName = User.Identity?.Name ?? "User";
    var nameParts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = nameParts.Length >= 2
        ? $"{char.ToUpper(nameParts[0][0])}{char.ToUpper(nameParts[^1][0])}"
        : userName.Length >= 2
            ? userName[..2].ToUpperInvariant()
            : userName.ToUpperInvariant();
}

<header class="app-topbar eh-header">
    <div class="eh-header-left">
        <button type="button" class="eh-header-btn sidebar-toggle-btn" data-sidebar-toggle aria-label="Toggle sidebar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
        <a asp-page="/Index" class="eh-header-logo d-none d-md-inline-flex">
            <span class="eh-header-logo-mark">EH</span>
            <span class="d-none d-lg-inline">EnhancementHub</span>
        </a>
        <span class="eh-header-workspace d-none d-xl-inline-flex" title="Workspace">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            Default workspace
        </span>
    </div>

    <div class="eh-header-center">
        <button type="button" class="eh-header-search eh-omnibox-trigger" data-command-trigger aria-label="Search (Ctrl+K or Cmd+K)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <path d="m20 20-3.5-3.5" />
            </svg>
            <span class="eh-header-search-label">Search workspace…</span>
            <kbd class="eh-kbd command-kbd" data-command-kbd>⌘K</kbd>
        </button>
    </div>

    <div class="eh-header-right topbar-actions">
        <button type="button" class="eh-header-btn eh-header-btn--ai d-none d-md-inline-flex" data-command-trigger aria-label="AI assistant" title="AI assistant — opens command palette">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3z" />
                <path d="M5 19l1 2 2 1-2 1-1 2-1-2-2-1 2-1 1-2z" />
            </svg>
            <span class="d-none d-lg-inline">AI</span>
        </button>
        <a href="/Spa/OnboardingWizard" class="eh-header-btn d-none d-lg-inline-flex" aria-label="Help and setup" title="Help">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M9.5 9.5a2.5 2.5 0 0 1 4 2c0 2-2.5 2-2.5 4" />
                <circle cx="12" cy="17" r="0.5" fill="currentColor" />
            </svg>
        </a>
        <div class="dropdown eh-topbar-dropdown">
            <button class="eh-header-btn position-relative" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-label="Notifications">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
                <span id="notification-badge" class="notification-badge d-none">0</span>
            </button>
            <div class="dropdown-menu dropdown-menu-end eh-dropdown-panel notification-panel">
                <div class="eh-dropdown-header">
                    <strong>Notifications</strong>
                    <button type="button" class="eh-dropdown-link-btn" id="notification-mark-read">Mark all read</button>
                </div>
                <div id="notification-list" class="notification-list"></div>
                <div class="eh-dropdown-footer">
                    <a href="/Spa/Account/Notifications">Notification preferences</a>
                </div>
            </div>
        </div>
        <button type="button" class="eh-header-btn d-none d-sm-inline-flex" data-theme-toggle aria-label="Toggle theme" title="Toggle theme">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 3a6 6 0 1 0 0 18 6 6 0 0 0 0-18z" />
            </svg>
        </button>
        <div id="eh-topbar-theme-slot" class="eh-topbar-theme topbar-theme-slot d-none"></div>
        <div class="dropdown eh-topbar-dropdown">
            <button class="eh-header-btn eh-topbar-user-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-auto-close="true" aria-expanded="false" aria-label="Account menu">
                <span class="eh-topbar-avatar" aria-hidden="true">@initials</span>
                <span class="eh-topbar-user-name d-none d-xl-inline">@userName</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end eh-dropdown-panel">
                <li><h6 class="dropdown-header">@userName</h6></li>
                <li><a class="dropdown-item" href="/Spa/Account/Notifications">Notification preferences</a></li>
                @if (User.IsInRole("Admin"))
                {
                    <li><a class="dropdown-item" href="/Spa/Settings/General">Settings</a></li>
                }
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form method="post" asp-page="/Account/Login" asp-page-handler="Logout" class="eh-dropdown-signout">
                        <button type="submit" class="dropdown-item text-danger">Sign out</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</header>
