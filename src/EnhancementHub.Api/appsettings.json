{
  "ConnectionStrings": {
    "Default": "Data Source=enhancementhub.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Jwt": {
    "Secret": "dev-secret-change-in-production-min-32-chars!!",
    "Issuer": "EnhancementHub",
    "Audience": "EnhancementHub",
    "ExpiryMinutes": 480
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "BaseUrl": "https://api.openai.com/v1/"
  },
  "AI": {
    "Provider": "OpenAI",
    "PiiRedactionEnabled": true,
    "Budget": {
      "Enabled": true,
      "DailyTokenLimit": 500000,
      "DailyCostLimitUsd": 50
    },
    "OpenAI": {
      "ApiKey": "",
      "BaseUrl": "https://api.openai.com/v1/",
      "Models": {
        "EnhancementAnalysis": "gpt-4o-mini",
        "RefactorPlan": "gpt-4o-mini"
      }
    },
    "AzureOpenAI": {
      "Endpoint": "https://your-resource.openai.azure.com",
      "ApiKey": "",
      "ApiVersion": "2024-02-15-preview",
      "Deployments": {
        "EnhancementAnalysis": "gpt-4o-mini",
        "RefactorPlan": "gpt-4o-mini"
      }
    }
  },
  "Cors": {
    "WebOrigin": "http://localhost:5001"
  },
  "Authentication": {
    "OpenIdConnect": {
      "Enabled": false,
      "Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-oidc",
      "SignedOutCallbackPath": "/signout-callback-oidc",
